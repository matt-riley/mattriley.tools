---
import Layout from "../../layouts/Layout.astro";
import { skills, skillsGeneratedAt } from "../../data/skills.generated";
import { formatUtcTimestamp } from "../../utils/date";
import { renderReadme } from "../../utils/readme";

interface Props {
  skill: (typeof skills)[number] & { homepage?: string | null };
}

export function getStaticPaths() {
  return skills.map((skill) => ({
    params: { slug: skill.slug },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const formattedSkillsGeneratedAt = formatUtcTimestamp(skillsGeneratedAt);
const skillHtml = renderReadme(skill.readme);
const pageUrl = `https://mattriley.tools/skills/${skill.slug}/`;
const licenseLabel = skill.license ?? "Undeclared";
const jsonld = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: skill.name,
  description: skill.description,
  url: pageUrl,
  isPartOf: {
    "@type": "SoftwareSourceCode",
    name: skill.repository,
    codeRepository: `https://github.com/${skill.repository}`,
  },
  version: skill.version,
  ...(skill.license ? { license: skill.license } : {}),
};
---

<Layout
  title={skill.name}
  description={skill.description}
  agentHint={[
    `This is the detail page for the ${skill.name} agent skill.`,
    "Skill metadata and instructions are generated from matt-riley/agent-skills SKILL.md files.",
    "The website renders skill instructions as inert documentation only; it does not install or run support files.",
  ]}
  jsonld={jsonld}
>
  <div class="vibrant-detail-page vibrant-magenta">
    <a href="/" class="back-link">← Back to Catalog</a>

    <header>
      <h1>{skill.name}</h1>
      <p style="font-size: 2rem; font-weight: bold; margin-bottom: 2rem;">{skill.description}</p>
      
      <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; font-weight: bold; font-size: 1.25rem;">
        <div>Version: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.version}</span></div>
        <div>Maturity: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.maturity}</span></div>
        <div>Repository: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.repository}</span></div>
        <div>License: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{licenseLabel}</span></div>
        {skill.homepage && <div>Homepage: <a href={skill.homepage} target="_blank" rel="noopener noreferrer" style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem; text-decoration: none;">Link ↗</a></div>}
      </div>
      
      <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 4rem;">
        <p style="margin-bottom: 1rem;">Compatibility:</p>
        <div style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; border: 4px solid #000;">
          {skill.compatibility}
        </div>
      </div>
    </header>

    <main>
      <h2>SKILL.md</h2>
      <div style="border-top: 8px solid #000; padding-top: 2rem; margin-top: 1rem;">
        {skill.readme.markdown ? (
          <div class="readme-content" set:html={skillHtml} />
        ) : (
          <p style="font-weight: bold; font-size: 1.5rem;">This skill does not currently have synced instruction content to display.</p>
        )}
      </div>
    </main>

    <footer style="margin-top: 4rem; border-top: 4px solid #000; padding-top: 2rem; font-weight: bold;">
      <p>Last synced: <time datetime={skillsGeneratedAt}>{formattedSkillsGeneratedAt}</time></p>
      <p><a href={skill.sourceUrl} target="_blank" rel="noopener">Open SKILL.md on GitHub</a></p>
    </footer>
  </div>
</Layout>
