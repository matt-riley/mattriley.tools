---
import CatalogDetail from "../../components/CatalogDetail.astro";
import { skills, skillsGeneratedAt } from "../../data/skills.generated";
import { formatSeoDescription, formatSeoTitle } from "../../utils/seo";

export function getStaticPaths() {
  return skills.map((skill) => ({
    params: { slug: skill.slug },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const jsonld = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: skill.name,
  description: skill.description,
  url: `https://mattriley.tools/skills/${skill.slug}/`,
  isPartOf: {
    "@type": "SoftwareSourceCode",
    name: skill.repository,
    codeRepository: `https://github.com/${skill.repository}`,
  },
  version: skill.version,
  ...(skill.license ? { license: skill.license } : {}),
};
---

<CatalogDetail
  title={formatSeoTitle(skill.name, "Agent Skill")}
  description={formatSeoDescription(skill.description, `Explore the ${skill.name} agent skill on mattriley.tools.`)}
  agentHint={[
    `This is the detail page for the ${skill.name} agent skill.`,
    "Skill metadata and instructions are generated from matt-riley/agent-skills SKILL.md files.",
    "The website renders skill instructions as inert documentation only; it does not install or run support files.",
  ]}
  jsonld={jsonld}
  domainClass="vibrant-magenta"
  name={skill.name}
  subtitle={skill.description}
  generatedAt={skillsGeneratedAt}
  sourceHref={skill.sourceUrl}
  sourceLabel="Open SKILL.md on GitHub"
  sectionTitle="SKILL.md"
  sectionAnchor="skills"
  fallbackText="This skill does not currently have synced instruction content to display."
  readme={skill.readme}
  ogType="article"
>
  <Fragment slot="metadata">
    <div>Version: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.version}</span></div>
    <div>Maturity: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.maturity}</span></div>
    <div>Repository: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.repository}</span></div>
    <div>License: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{skill.license ?? "Undeclared"}</span></div>
    {skill.homepage && <div>Homepage: <a href={skill.homepage} target="_blank" rel="noopener noreferrer" style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem; text-decoration: none;">Link ↗</a></div>}
  </Fragment>

  <Fragment slot="extra">
    <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 4rem;">
      <p style="margin-bottom: 1rem;">Compatibility:</p>
      <div style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; border: 4px solid #000;">
        {skill.compatibility}
      </div>
    </div>
  </Fragment>
</CatalogDetail>
