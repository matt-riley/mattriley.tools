---
import Layout from "../../layouts/Layout.astro";
import { plugins, pluginsGeneratedAt } from "../../data/plugins.generated";
import { formatUtcTimestamp } from "../../utils/date";
import { renderReadme } from "../../utils/readme";

interface Props {
  plugin: (typeof plugins)[number];
}

export function getStaticPaths() {
  return plugins.map((plugin) => ({
    params: { slug: plugin.slug },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const formattedPluginsGeneratedAt = formatUtcTimestamp(pluginsGeneratedAt);
const readmeHtml = renderReadme(plugin.readme);
const pageUrl = `https://mattriley.tools/plugins/${plugin.slug}/`;
const topicCount = Number(plugin.topics.length);
const topicLabel = topicCount === 1 ? "topic" : "topics";
const languageLabel = plugin.language ?? "Unknown";
const jsonld = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: plugin.name,
  description: plugin.description,
  url: pageUrl,
  codeRepository: plugin.homepage,
  version: plugin.version,
  ...(plugin.language ? { programmingLanguage: plugin.language } : {}),
  ...(plugin.topics.length > 0 ? { keywords: plugin.topics.join(", ") } : {}),
};
---

<Layout
  title={plugin.name}
  description={plugin.description}
  agentHint={[
    `This is the detail page for the ${plugin.name} Neovim plugin.`,
    "Repository metadata comes from GitHub and install snippets are generated for lazy.nvim and vim.pack.",
    "README content is synced from the plugin repository when available.",
  ]}
  jsonld={jsonld}
>
  <div class="vibrant-detail-page vibrant-green">
    <a href="/" class="back-link">← Back to Catalog</a>

    <header>
      <h1>{plugin.name}</h1>
      <p style="font-size: 2rem; font-weight: bold; margin-bottom: 2rem;">{plugin.description}</p>
      
      <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; font-weight: bold; font-size: 1.25rem;">
        <div>Version: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{plugin.version}</span></div>
        <div>Language: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{languageLabel}</span></div>
        <div>Topics: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{topicCount}</span></div>
        {plugin.homepage && <div>Homepage: <a href={plugin.homepage} target="_blank" rel="noopener noreferrer" style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem; text-decoration: none;">Link ↗</a></div>}
      </div>

      <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 2rem;">
        <p style="margin-bottom: 1rem;">Install (lazy.nvim):</p>
        <code style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; display: block; border: 4px solid #000;">
          {plugin.lazyInstallSnippet}
        </code>
      </div>
      
      <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 4rem;">
        <p style="margin-bottom: 1rem;">Install (vim.pack):</p>
        <code style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; display: block; border: 4px solid #000;">
          {plugin.vimPackInstallSnippet}
        </code>
      </div>
    </header>

    <main>
      <h2>README</h2>
      <div style="border-top: 8px solid #000; padding-top: 2rem; margin-top: 1rem;">
        {plugin.readme.markdown ? (
          <div class="readme-content" set:html={readmeHtml} />
        ) : (
          <p style="font-weight: bold; font-size: 1.5rem;">This plugin does not currently have synced README content to display.</p>
        )}
      </div>
    </main>

    <footer style="margin-top: 4rem; border-top: 4px solid #000; padding-top: 2rem; font-weight: bold;">
      <p>Last synced: <time datetime={pluginsGeneratedAt}>{formattedPluginsGeneratedAt}</time></p>
      <p><a href={plugin.homepage} target="_blank" rel="noopener">Open GitHub repository</a></p>
    </footer>
  </div>
</Layout>
