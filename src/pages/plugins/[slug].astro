---
import CatalogDetail from "../../components/CatalogDetail.astro";
import { plugins, pluginsGeneratedAt } from "../../data/plugins.generated";
import { formatSeoDescription, formatSeoTitle } from "../../utils/seo";

export function getStaticPaths() {
  return plugins.map((plugin) => ({
    params: { slug: plugin.slug },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const jsonld = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: plugin.name,
  description: plugin.description,
  url: `https://mattriley.tools/plugins/${plugin.slug}/`,
  codeRepository: plugin.homepage,
  version: plugin.version,
  ...(plugin.language ? { programmingLanguage: plugin.language } : {}),
  ...(plugin.topics.length > 0 ? { keywords: plugin.topics.join(", ") } : {}),
};
---

<CatalogDetail
  title={formatSeoTitle(plugin.name, "Neovim Plugin")}
  description={formatSeoDescription(plugin.description, `${plugin.name} ${plugin.version} — Neovim plugin on mattriley.tools.`)}
  agentHint={[
    `This is the detail page for the ${plugin.name} Neovim plugin.`,
    "Repository metadata comes from GitHub and install snippets are generated for lazy.nvim and vim.pack.",
    "README content is synced from the plugin repository when available.",
  ]}
  jsonld={jsonld}
  domainClass="vibrant-green"
  name={plugin.name}
  subtitle={plugin.description}
  generatedAt={pluginsGeneratedAt}
  sourceHref={plugin.homepage}
  sourceLabel="Open GitHub repository"
  sectionTitle="README"
  sectionAnchor="plugins"
  fallbackText="This plugin does not currently have synced README content to display."
  readme={plugin.readme}
  ogType="article"
>
  <Fragment slot="metadata">
    <div>Version: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{plugin.version}</span></div>
    <div>Language: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{plugin.language ?? "Unknown"}</span></div>
    <div>Topics: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{Number(plugin.topics.length)}</span></div>
    {plugin.homepage && <div>Homepage: <a href={plugin.homepage} target="_blank" rel="noopener noreferrer" style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem; text-decoration: none;">Link ↗</a></div>}
  </Fragment>

  <Fragment slot="extra">
    <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 2rem;">
      <p style="margin-bottom: 1rem;">Install (lazy.nvim):</p>
      <code style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; display: block; border: 4px solid #000;">
        {plugin.lazyInstallSnippet}
      </code>
    </div>

    <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 4rem;">
      <p style="margin-bottom: 1rem;">Install (vim.pack):</p>
      <code style="background: #000; color: var(--accent-color); padding: 1rem 1.5rem; display: block; border: 4px solid #000;">
        {plugin.vimPackInstallSnippet}
      </code>
    </div>
  </Fragment>
</CatalogDetail>
