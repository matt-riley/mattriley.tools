---
import Layout from "../layouts/Layout.astro";
import { generatedAt, tools } from "../data/tools.generated";
import { plugins, pluginsGeneratedAt } from "../data/plugins.generated";
import { templates, templatesGeneratedAt } from "../data/templates.generated";
import { skills, skillsGeneratedAt } from "../data/skills.generated";
import { formatUtcTimestamp } from "../utils/date";

const pageUrl = "https://mattriley.tools/";
const description =
  "Static catalog of Matt Riley's Homebrew tools, Neovim plugins, agent skills, and public template repositories.";
const formattedGeneratedAt = formatUtcTimestamp(generatedAt);
const formattedPluginsGeneratedAt = formatUtcTimestamp(pluginsGeneratedAt);
const formattedTemplatesGeneratedAt = formatUtcTimestamp(templatesGeneratedAt);
const formattedSkillsGeneratedAt = formatUtcTimestamp(skillsGeneratedAt);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "mattriley.tools",
  description,
  url: pageUrl,
  hasPart: [
    {
      "@type": "ItemList",
      name: "Homebrew tools",
      numberOfItems: tools.length,
      url: `${pageUrl}#homebrew-tools`,
    },
    {
      "@type": "ItemList",
      name: "Neovim plugins",
      numberOfItems: plugins.length,
      url: `${pageUrl}#neovim-plugins`,
    },
    {
      "@type": "ItemList",
      name: "Agent skills",
      numberOfItems: skills.length,
      url: `${pageUrl}#agent-skills`,
    },
    {
      "@type": "ItemList",
      name: "Public templates",
      numberOfItems: templates.length,
      url: `${pageUrl}#public-templates`,
    },
  ],
};
---

<Layout
  title="mattriley.tools"
  description={description}
  agentHint={[
    "This page is a static catalog of Matt Riley's published Homebrew tools, Neovim plugins, agent skills, and public template repositories.",
    "Catalog entries link to detail pages that include generated metadata and synced README content.",
  ]}
  jsonld={jsonld}
>
  <div class="vibrant-detail-page">
    <header style="margin-bottom: 6rem;">
      <h1 style="font-size: 8rem; border-bottom: none; margin-bottom: 1rem;">MATTRILEY.TOOLS</h1>
      <p style="font-size: 2.5rem; font-weight: 900; text-transform: uppercase;">A static catalog of Homebrew tools, Neovim plugins, agent skills, and public template repositories.</p>
      <div style="display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">
        <a href="#homebrew-tools" style="background: #000; color: #FFF; padding: 1rem 2rem; font-weight: bold; text-decoration: none; text-transform: uppercase; border: 4px solid #000; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='8px 8px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">Tools</a>
        <a href="#neovim-plugins" style="background: #000; color: #FFF; padding: 1rem 2rem; font-weight: bold; text-decoration: none; text-transform: uppercase; border: 4px solid #000; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='8px 8px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">Plugins</a>
        <a href="#agent-skills" style="background: #000; color: #FFF; padding: 1rem 2rem; font-weight: bold; text-decoration: none; text-transform: uppercase; border: 4px solid #000; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='8px 8px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">Skills</a>
        <a href="#public-templates" style="background: #000; color: #FFF; padding: 1rem 2rem; font-weight: bold; text-decoration: none; text-transform: uppercase; border: 4px solid #000; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='8px 8px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">Templates</a>
      </div>
    </header>

    <section id="homebrew-tools" style="margin-bottom: 6rem;">
      <h2 style="font-size: 4rem; border-bottom: 8px solid #000; padding-bottom: 1rem; margin-bottom: 1rem;">Homebrew Tools</h2>
      <p style="font-size: 1.5rem; font-weight: bold;">Last synced: <time datetime={generatedAt}>{formattedGeneratedAt}</time></p>
      {tools.length > 0 ? (
        <div class="domain-grid">
          {tools.map(tool => (
            <a href={`/tools/${tool.slug}/`} class="catalog-card cyan-card">
              <h3 class="card-title">{tool.name}</h3>
              <p class="card-desc">{tool.description}</p>
              <div class="card-meta">
                <span class="version">v{tool.version}</span>
                <code class="install-cmd">{tool.installCommand}</code>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-size: 2rem; font-weight: bold; margin-top: 2rem;">No Homebrew tools are published yet</p>
      )}
    </section>

    <!-- Plugins -->
    <section id="neovim-plugins" style="margin-bottom: 6rem;">
      <h2 style="font-size: 4rem; border-bottom: 8px solid #000; padding-bottom: 1rem; margin-bottom: 1rem;">Neovim Plugins</h2>
      <p style="font-size: 1.5rem; font-weight: bold;">Last synced: <time datetime={pluginsGeneratedAt}>{formattedPluginsGeneratedAt}</time></p>
      {plugins.length > 0 ? (
        <div class="domain-grid">
          {plugins.map(plugin => (
            <a href={`/plugins/${plugin.slug}/`} class="catalog-card green-card">
              <h3 class="card-title">{plugin.name}</h3>
              <p class="card-desc">{plugin.description}</p>
              <div class="card-meta">
                <span class="version">v{plugin.version}</span>
                <span style="background: #000; padding: 0.25rem 0.5rem; color: var(--accent-color);">{plugin.language ?? "Unknown"}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-size: 2rem; font-weight: bold; margin-top: 2rem;">No Neovim plugins matched the catalog rules</p>
      )}
    </section>

    <!-- Skills -->
    <section id="agent-skills" style="margin-bottom: 6rem;">
      <h2 style="font-size: 4rem; border-bottom: 8px solid #000; padding-bottom: 1rem; margin-bottom: 1rem;">Agent Skills</h2>
      <p style="font-size: 1.5rem; font-weight: bold;">Last synced: <time datetime={skillsGeneratedAt}>{formattedSkillsGeneratedAt}</time></p>
      {skills.length > 0 ? (
        <div class="domain-grid">
          {skills.map(skill => (
            <a href={`/skills/${skill.slug}/`} class="catalog-card magenta-card">
              <h3 class="card-title">{skill.name}</h3>
              <p class="card-desc">{skill.description}</p>
              <div class="card-meta">
                <span class="version">v{skill.version}</span>
                <span style="background: #000; padding: 0.25rem 0.5rem; color: var(--accent-color);">{skill.maturity}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-size: 2rem; font-weight: bold; margin-top: 2rem;">No agent skills are published yet</p>
      )}
    </section>

    <!-- Templates -->
    <section id="public-templates" style="margin-bottom: 6rem;">
      <h2 style="font-size: 4rem; border-bottom: 8px solid #000; padding-bottom: 1rem; margin-bottom: 1rem;">Public Templates</h2>
      <p style="font-size: 1.5rem; font-weight: bold;">Last synced: <time datetime={templatesGeneratedAt}>{formattedTemplatesGeneratedAt}</time></p>
      {templates.length > 0 ? (
        <div class="domain-grid">
          {templates.map(template => (
            <a href={`/templates/${template.slug}/`} class="catalog-card orange-card">
              <h3 class="card-title">{template.name}</h3>
              <p class="card-desc">{template.description}</p>
              <div class="card-meta">
                <span class="version">{template.language ?? "Unknown"}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="font-size: 2rem; font-weight: bold; margin-top: 2rem;">No public templates matched the current GitHub filters</p>
      )}
    </section>
  </div>
</Layout>
