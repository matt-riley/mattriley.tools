---
import {
  Badge,
  BentoGrid,
  BentoItem,
  Callout,
  DataTable,
  EmptyState,
  Hero,
  LinkButton,
  PageShell,
  Panel,
  Section,
  Stack,
  StatCard,
} from "@matt-riley/ui-astro";
import Layout from "../layouts/Layout.astro";
import { generatedAt, tools } from "../data/tools.generated";
import { plugins, pluginsGeneratedAt } from "../data/plugins.generated";
import { templates, templatesGeneratedAt } from "../data/templates.generated";
import { skills, skillsGeneratedAt } from "../data/skills.generated";
import { formatUtcTimestamp } from "../utils/date";
import type { SyncedReadmeImage } from "../utils/readme";

const pageUrl = "https://mattriley.tools/";
const description =
  "Static catalog of Matt Riley's Homebrew tools, Neovim plugins, agent skills, and public template repositories.";
const formattedGeneratedAt = formatUtcTimestamp(generatedAt);
const formattedPluginsGeneratedAt = formatUtcTimestamp(pluginsGeneratedAt);
const formattedTemplatesGeneratedAt = formatUtcTimestamp(templatesGeneratedAt);
const formattedSkillsGeneratedAt = formatUtcTimestamp(skillsGeneratedAt);
const allEntries = [...tools, ...plugins, ...templates, ...skills];
const syncedReadmeCount = allEntries.filter((entry) => entry.readme.markdown.trim().length > 0).length;
const allReadmeImages: SyncedReadmeImage[] = allEntries.flatMap((entry) => [
  ...entry.readme.images,
]) as SyncedReadmeImage[];
const mirroredReadmeAssetCount = allReadmeImages.filter((image) => image.mirroredPath).length;
const jsonld = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "mattriley.tools",
  description,
  url: pageUrl,
  hasPart: [
    {
      "@type": "ItemList",
      name: "Homebrew tools",
      numberOfItems: tools.length,
      url: `${pageUrl}#homebrew-tools`,
    },
    {
      "@type": "ItemList",
      name: "Neovim plugins",
      numberOfItems: plugins.length,
      url: `${pageUrl}#neovim-plugins`,
    },
    {
      "@type": "ItemList",
      name: "Agent skills",
      numberOfItems: skills.length,
      url: `${pageUrl}#agent-skills`,
    },
    {
      "@type": "ItemList",
      name: "Public templates",
      numberOfItems: templates.length,
      url: `${pageUrl}#public-templates`,
    },
  ],
};
---

<Layout
  title="mattriley.tools"
  description={description}
  agentHint={[
    "This page is a static catalog of Matt Riley's published Homebrew tools, Neovim plugins, agent skills, and public template repositories.",
    "Catalog entries link to detail pages that include generated metadata and synced README content.",
  ]}
  jsonld={jsonld}
>
  <PageShell>
    <div class="page-stack">
      <Panel variant="glass" class="hero-panel">
        <Hero
          title="mattriley.tools"
          variant="display"
          lede="A static catalog of the Homebrew tools, Neovim plugins, agent skills, and public template repositories Matt ships publicly. Tool data is generated from the tap's formula files; plugin and template data are generated from public GitHub repositories; skill data is generated from portable SKILL.md files."
        >
          <div class="hero-badges" aria-label="Site highlights">
            <Badge variant="info">Static Astro catalog</Badge>
            <Badge>Snurble powered</Badge>
            <Badge variant="success">README sync included</Badge>
          </div>

          <div class="hero-actions">
            <LinkButton href="#homebrew-tools" size="lg">Browse tools</LinkButton>
            <LinkButton href="#neovim-plugins" variant="secondary">Browse plugins</LinkButton>
            <LinkButton href="#agent-skills" variant="secondary">Browse skills</LinkButton>
            <LinkButton href="#public-templates" variant="secondary">Browse templates</LinkButton>
          </div>
        </Hero>
      </Panel>

      <Section title="Catalog at a glance" headingId="catalog-overview" decorated spacing={5}>
        <Stack space={4}>
          <BentoGrid columns={1} columnsMd={2} columnsLg={4} gap={4}>
            <BentoItem>
              <StatCard
                label="Homebrew tools"
                value={tools.length}
                trendValue={formattedGeneratedAt}
                href="#homebrew-tools"
              />
            </BentoItem>
            <BentoItem>
              <StatCard
                label="Neovim plugins"
                value={plugins.length}
                trendValue={formattedPluginsGeneratedAt}
                href="#neovim-plugins"
              />
            </BentoItem>
            <BentoItem>
              <StatCard
                label="Agent skills"
                value={skills.length}
                trendValue={formattedSkillsGeneratedAt}
                href="#agent-skills"
              />
            </BentoItem>
            <BentoItem>
              <StatCard
                label="Public templates"
                value={templates.length}
                trendValue={formattedTemplatesGeneratedAt}
                href="#public-templates"
              />
            </BentoItem>
            <BentoItem>
              <StatCard
                label="Mirrored README assets"
                value={mirroredReadmeAssetCount}
                trendValue={`${syncedReadmeCount} synced documents`}
              />
            </BentoItem>
          </BentoGrid>

          <Callout title="Generated, not hand-curated" variant="tip">
            <span slot="icon">✨</span>
            <p>
              Every catalog on this site is rebuilt from repository metadata, formula files, portable
              skill files, and synced README content before Astro publishes the final static pages.
            </p>
          </Callout>
        </Stack>
      </Section>

      <Section title="Homebrew tools" headingId="homebrew-tools" decorated spacing={5}>
        <Stack space={4}>
          <Panel variant="glass" class="catalog-intro">
            <div class="section-copy">
              <p>
                Each entry links to a static detail page with the packaged version, install command,
                supported platforms, binary name, and source repository.
              </p>
              <p>Last synced: <time datetime={generatedAt}>{formattedGeneratedAt}</time></p>
            </div>
          </Panel>

          {
            tools.length > 0 ? (
              <DataTable labelledBy="homebrew-tools" striped>
                <tr slot="head">
                  <th scope="col">Tool</th>
                  <th scope="col">Version</th>
                  <th scope="col">Description</th>
                  <th scope="col">Install</th>
                </tr>
                {
                  tools.map((tool) => (
                    <tr>
                      <td data-label="Tool">
                        <a href={`/tools/${tool.slug}/`}>{tool.name}</a>
                      </td>
                      <td data-label="Version">{tool.version}</td>
                      <td data-label="Description">{tool.description}</td>
                      <td data-label="Install">
                        <code>{tool.installCommand}</code>
                      </td>
                    </tr>
                  ))
                }
              </DataTable>
            ) : (
              <EmptyState
                title="No Homebrew tools are published yet"
                description="Run the generator again after the tap includes at least one public formula-backed tool."
              />
            )
          }
        </Stack>
      </Section>

      <Section title="Neovim plugins" headingId="neovim-plugins" decorated spacing={5}>
        <Stack space={4}>
          <Panel variant="glass" class="catalog-intro">
            <div class="section-copy">
              <p>
                Non-archived public repositories from Matt's GitHub account whose names contain{" "}
                <code>.nvim</code>. Each entry links to plugin details with <code>lazy.nvim</code> and{" "}
                <code>vim.pack</code> install snippets.
              </p>
              <p>
                Last synced: <time datetime={pluginsGeneratedAt}>{formattedPluginsGeneratedAt}</time>
              </p>
            </div>
          </Panel>

          {
            plugins.length > 0 ? (
              <DataTable labelledBy="neovim-plugins" striped>
                <tr slot="head">
                  <th scope="col">Plugin</th>
                  <th scope="col">Version</th>
                  <th scope="col">Description</th>
                </tr>
                {
                  plugins.map((plugin) => (
                    <tr>
                      <td data-label="Plugin">
                        <a href={`/plugins/${plugin.slug}/`}>{plugin.name}</a>
                      </td>
                      <td data-label="Version">{plugin.version}</td>
                      <td data-label="Description">{plugin.description}</td>
                    </tr>
                  ))
                }
              </DataTable>
            ) : (
              <EmptyState
                title="No public Neovim plugins matched the catalog rules"
                description="Public, non-archived repositories with .nvim in the name will appear here after the next sync."
              />
            )
          }
        </Stack>
      </Section>

      <Section title="Agent skills" headingId="agent-skills" decorated spacing={5}>
        <Stack space={4}>
          <Panel variant="glass" class="catalog-intro">
            <div class="section-copy">
              <p>
                Portable agent skills from <code>matt-riley/agent-skills</code>. Each entry links to a
                static detail page with SKILL.md metadata, compatibility notes, and rendered
                instruction content.
              </p>
              <p>
                Last synced: <time datetime={skillsGeneratedAt}>{formattedSkillsGeneratedAt}</time>
              </p>
            </div>
          </Panel>

          {
            skills.length > 0 ? (
              <DataTable labelledBy="agent-skills" striped>
                <tr slot="head">
                  <th scope="col">Skill</th>
                  <th scope="col">Maturity</th>
                  <th scope="col">Description</th>
                </tr>
                {
                  skills.map((skill) => (
                    <tr>
                      <td data-label="Skill">
                        <a href={`/skills/${skill.slug}/`}>{skill.name}</a>
                      </td>
                      <td data-label="Maturity">{skill.maturity}</td>
                      <td data-label="Description">{skill.description}</td>
                    </tr>
                  ))
                }
              </DataTable>
            ) : (
              <EmptyState
                title="No agent skills are published yet"
                description="Skill directories with SKILL.md files appear here after the generator syncs matt-riley/agent-skills."
              />
            )
          }
        </Stack>
      </Section>

      <Section title="Public templates" headingId="public-templates" decorated spacing={5}>
        <Stack space={4}>
          <Panel variant="glass" class="catalog-intro">
            <div class="section-copy">
              <p>
                Non-archived public repositories from Matt's GitHub account that GitHub marks as
                template repos. Each entry links to template details with repository metadata and
                synced README content.
              </p>
              <p>
                Last synced: <time datetime={templatesGeneratedAt}>{formattedTemplatesGeneratedAt}</time>
              </p>
            </div>
          </Panel>

          {
            templates.length > 0 ? (
              <DataTable labelledBy="public-templates" striped>
                <tr slot="head">
                  <th scope="col">Template</th>
                  <th scope="col">Language</th>
                  <th scope="col">Description</th>
                </tr>
                {
                  templates.map((template) => (
                    <tr>
                      <td data-label="Template">
                        <a href={`/templates/${template.slug}/`}>{template.name}</a>
                      </td>
                      <td data-label="Language">{template.language ?? "Unknown"}</td>
                      <td data-label="Description">{template.description}</td>
                    </tr>
                  ))
                }
              </DataTable>
            ) : (
              <EmptyState
                title="No public templates matched the current GitHub filters"
                description="Template repositories appear here once GitHub marks them as templates and the generator syncs them."
              />
            )
          }
        </Stack>
      </Section>
    </div>
  </PageShell>
</Layout>
