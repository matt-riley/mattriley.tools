---
import CatalogDetail from "../../components/CatalogDetail.astro";
import { templates, templatesGeneratedAt } from "../../data/templates.generated";
import { formatSeoDescription, formatSeoTitle } from "../../utils/seo";

export function getStaticPaths() {
  return templates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props;
const jsonld = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: template.name,
  description: template.description,
  url: `https://mattriley.tools/templates/${template.slug}/`,
  codeRepository: template.homepage,
  ...(template.language ? { programmingLanguage: template.language } : {}),
  ...(template.topics.length > 0 ? { keywords: template.topics.join(", ") } : {}),
};
---

<CatalogDetail
  title={formatSeoTitle(template.name, "Public Template")}
  description={formatSeoDescription(template.description, `Use ${template.name} as a starting point for your next project on mattriley.tools.`)}
  agentHint={[
    `This is the detail page for the ${template.name} public template repository.`,
    "Repository metadata comes from GitHub and the README is synced into this static site when available.",
    "Use the linked GitHub repository to create a new project from the template.",
  ]}
  jsonld={jsonld}
  domainClass="vibrant-orange"
  name={template.name}
  subtitle={template.description}
  generatedAt={templatesGeneratedAt}
  sourceHref={template.homepage}
  sourceLabel="Open on GitHub"
  sectionTitle="README"
  sectionAnchor="templates"
  fallbackText="This template does not currently have synced README content to display."
  readme={template.readme}
  ogType="article"
>
  <Fragment slot="metadata">
    <div>Language: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{template.language ?? "Unknown"}</span></div>
    <div>Topics: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{Number(template.topics.length)}</span></div>
    {template.homepage && <div>Homepage: <a href={template.homepage} target="_blank" rel="noopener noreferrer" style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem; text-decoration: none;">Link ↗</a></div>}
  </Fragment>
</CatalogDetail>
