---
import Layout from "../../layouts/Layout.astro";
import { templates, templatesGeneratedAt } from "../../data/templates.generated";
import { formatUtcTimestamp } from "../../utils/date";
import { renderReadme } from "../../utils/readme";

interface Props {
  template: (typeof templates)[number];
}

export function getStaticPaths() {
  return templates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props;
const formattedTemplatesGeneratedAt = formatUtcTimestamp(templatesGeneratedAt);
const readmeHtml = renderReadme(template.readme);
const pageUrl = `https://mattriley.tools/templates/${template.slug}/`;
const topicCount = Number(template.topics.length);
const topicLabel = topicCount === 1 ? "topic" : "topics";
const languageLabel = template.language ?? "Unknown";
const jsonld = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: template.name,
  description: template.description,
  url: pageUrl,
  codeRepository: template.homepage,
  ...(template.language ? { programmingLanguage: template.language } : {}),
  ...(template.topics.length > 0 ? { keywords: template.topics.join(", ") } : {}),
};
---

<Layout
  title={template.name}
  description={template.description}
  agentHint={[
    `This is the detail page for the ${template.name} public template repository.`,
    "Repository metadata comes from GitHub and the README is synced into this static site when available.",
    "Use the linked GitHub repository to create a new project from the template.",
  ]}
  jsonld={jsonld}
>
  <div class="vibrant-detail-page vibrant-orange">
    <a href="/" style="color: #000; font-weight: bold; text-decoration: none; display: inline-block; margin-bottom: 2rem; border-bottom: 4px solid #000;">← Back to Catalog</a>

    <header>
      <h1>{template.name}</h1>
      <p style="font-size: 2rem; font-weight: bold; margin-bottom: 2rem;">{template.description}</p>
      
      <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 4rem; font-weight: bold; font-size: 1.25rem;">
        <div>Language: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{languageLabel}</span></div>
        <div>Topics: <span style="background: #000; color: var(--accent-color); padding: 0.25rem 0.5rem;">{topicCount}</span></div>
      </div>
    </header>

    <main>
      <h2>README</h2>
      <div style="border-top: 8px solid #000; padding-top: 2rem; margin-top: 1rem;">
        {template.readme.markdown ? (
          <div class="readme-content" set:html={readmeHtml} />
        ) : (
          <p style="font-weight: bold; font-size: 1.5rem;">This template does not currently have synced README content to display.</p>
        )}
      </div>
    </main>

    <footer style="margin-top: 4rem; border-top: 4px solid #000; padding-top: 2rem; font-weight: bold;">
      <p>Last synced: <time datetime={templatesGeneratedAt}>{formattedTemplatesGeneratedAt}</time></p>
      <p><a href={template.homepage} target="_blank" rel="noopener">Open on GitHub</a></p>
    </footer>
  </div>
</Layout>
