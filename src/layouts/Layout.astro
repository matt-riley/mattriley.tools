---
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  agentHint?: string | readonly string[];
  jsonld?: unknown;
  pageTitle?: string;
}

const { title, description, agentHint, jsonld, pageTitle } = Astro.props;
const resolvedPageTitle = pageTitle ?? (title === "mattriley.tools" ? title : `${title} | mattriley.tools`);
const agentHintHtml = agentHint ? `<!-- AGENT DISCOVERY HINT:\n${Array.isArray(agentHint) ? agentHint.join("\n") : agentHint}\n-->` : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <Seo 
      title={resolvedPageTitle} 
      description={description || 'Curated tools, plugins, skills, and templates for modern development.'} 
      canonicalUrl={new URL(Astro.url.pathname, Astro.site).href} 
    />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  </head>
  <body>
    <slot />
    {agentHint && <Fragment set:html={agentHintHtml} />}
  </body>
</html>
