---
import "../styles/global.css";
import { AgentDiscoveryHint, JsonLd, Layout as SnurbleLayout } from "@matt-riley/ui-astro";

interface Props {
  title: string;
  description?: string;
  agentHint?: string | readonly string[];
  jsonld?: unknown;
}

const { title, description, agentHint, jsonld } = Astro.props;
const pageTitle = title === "mattriley.tools" ? title : `${title} | mattriley.tools`;
---

<SnurbleLayout title={pageTitle} description={description}>
  <link slot="head" rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link slot="head" rel="icon" href="/favicon.ico" />
  <meta slot="head" name="generator" content={Astro.generator} />
  {jsonld && <JsonLd slot="head" jsonld={jsonld} />}
  <slot />
  {agentHint && <AgentDiscoveryHint hint={agentHint} />}
</SnurbleLayout>
