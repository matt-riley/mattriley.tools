---
import "../styles/global.css";
import { AgentDiscoveryHint, JsonLd } from "@matt-riley/ui-astro";

interface Props {
  title: string;
  description?: string;
  agentHint?: string | readonly string[];
  jsonld?: unknown;
}

const { title, description, agentHint, jsonld } = Astro.props;
const pageTitle = title === "mattriley.tools" ? title : `${title} | mattriley.tools`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    {jsonld && <JsonLd jsonld={jsonld} />}
  </head>
  <body>
    <slot />
    {agentHint && <AgentDiscoveryHint hint={agentHint} />}
  </body>
</html>
